# CopyLingo Environment Variables File (.env)
# ----------------------------------------------------
# 복사 붙여넣기 후 .env 파일 이름으로 사용하십시오.
# 시스템 환경변수 설정보다 우선 순위가 낮으며, 로컬 개발/테스트에 사용합니다.

# Telegram Bot Token (필수)
# @BotFather 에서 발급받은 토큰
COPYLINGO_TELEGRAM_TOKEN=123456789:ABCDefghijklmnopqrstuvwxyz

# OpenAI API Key (필수)
# Gemini OpenAI 호환 API Key 등
COPYLINGO_OPENAI_API_KEY=dummy_key_for_now

# Database Options (docker-compose의 .env나 config.yaml에 없는 경우 오버라이드 가능)
# COPYLINGO_DB_HOST=localhost
# COPYLINGO_DB_PORT=5432
# COPYLINGO_DB_USER=copylingo
# COPYLINGO_DB_PASSWORD=copylingo
# COPYLINGO_DB_DBNAME=copylingo
